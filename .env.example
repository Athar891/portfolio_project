# ===================================
# Email Configuration
# ===================================
# Choose email provider: 'smtp' or 'gmail'
EMAIL_PROVIDER=smtp

# SMTP Configuration (if using SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@yourdomain.com

# Gmail Configuration (if using Gmail provider)
# GMAIL_USER=your-email@gmail.com
# GMAIL_APP_PASSWORD=your-16-character-app-password

# Developer Email (where contact form submissions are sent)
DEVELOPER_EMAIL=your-email@example.com

# ===================================
# Rate Limiting Configuration
# ===================================
# Maximum contact form submissions per IP per hour
RATE_LIMIT_MAX_REQUESTS=5
RATE_LIMIT_WINDOW_MS=3600000

# ===================================
# Security Configuration
# ===================================
# Enable/disable spam detection
ENABLE_SPAM_DETECTION=true

# Enable/disable user confirmation emails
SEND_CONFIRMATION_EMAIL=true

# ===================================
# Database Configuration (Optional)
# ===================================
# DATABASE_URL=postgresql://user:password@localhost:5432/portfolio_db
# ENABLE_MESSAGE_LOGGING=false

# ===================================
# Environment
# ===================================
NODE_ENV=development
